ialog to show every time\n\n        val client: SettingsClient \u003d LocationServices.getSettingsClient(context)\n        val task: Task\u003cLocationSettingsResponse\u003e \u003d client.checkLocationSettings(builder.build())\n\n        try {\n            task.await()\n            Result.success(Unit)\n        } catch (e: ResolvableApiException) {\n            // This exception can be resolved by showing the location dialog\n            Result.failure(e)\n        }\n    } catch (e: Exception) {\n        Result.failure(e)\n    }\n\n    @SuppressLint(\&quot;MissingPermission\&quot;)\n    fun getLocationUpdates(intervalMs: Long \u003d 5000): Flow\u003cLocation\u003e \u003d callbackFlow {\n        val locationRequest \u003d LocationRequest.Builder(Priority.PRIORITY_HIGH_ACCURACY, intervalMs)\n            .setMinUpdateDistanceMeters(5f)\n            .build()\n\n        val callback \u003d object : LocationCallback() {\n            override fun onLocationResult(result: LocationResult) {\n                result.lastLocation?.let { location -\u003e\n                    trySend(location)\n                }\n            }\n        }\n\n        fusedLocationClient.requestLocationUpdates(\n            locationRequest,\n            callback,\n            Looper.getMainLooper()\n        )\n\n        awaitClose {\n            fusedLocationClient.removeLocationUpdates(callback)\n        }\n    }\n}\n```&quot;},{&quot;role&quot;:&quot;assistant&quot;,&quot;content&quot;:[{&quot;type&quot;:&quot;text&quot;,&quot;text&quot;:&quot;\n\nNow let\u0027s check the Gradle files to verify Google Maps dependencies:&quot;}],&quot;tool_calls&quot;:[{&quot;id&quot;:&quot;toolu_bdrk_015LA1MzZbLPaHBwXxgCLLE8&quot;,&quot;type&quot;:&quot;function&quot;,&quot;function&quot;:{&quot;name&quot;:&quot;read_file&quot;,&quot;arguments&quot;:&quot;{\&quot;relative_workspace_path\&quot;: \&quot;app/build.gradle\&quot;, \&quot;explanation\&quot;: \&quot;Checking app-level build.gradle for Google Maps depende