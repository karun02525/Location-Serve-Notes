+@Composable
+fun AudioWaveform(isActive: Boolean, modifier: Modifier = Modifier) {
+    val barsCount = 40
+    Row(
+        modifier = modifier,
+        horizontalArrangement = Arrangement.SpaceBetween,
+        verticalAlignment = Alignment.CenterVertically
+    ) {
+        for (i in 0 until barsCount) {
