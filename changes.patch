GroupTabs(\n            selectedOption \u003d groupOption,\n            onOptionSelected \u003d { groupOption \u003d it }\n        )\n\n        when (groupOption) {\n            PhotoGroupOption.BY_DATE_CATEGORY -\u003e {\n                GroupedPhotosContent(photos, onDeletePhoto)\n            }\n\n            PhotoGroupOption.BY_MONTH -\u003e {\n                MonthlyGroupedPhotosContent(photos, onDeletePhoto)\n            }\n\n            PhotoGroupOption.ALL -\u003e {\n                AllPhotosContent(photos, onDeletePhoto)\n            }\n        }\n    }\n}\n\n@Composable\nfun PhotoGroupTabs(\n    selectedOption: PhotoGroupOption,\n    onOptionSelected: (PhotoGroupOption) -\u003e Unit\n) {\n    TabRow(\n        selectedTabIndex \u003d selectedOption.ordinal\n    ) {\n        Tab(\n            selected \u003d selectedOption \u003d\u003d PhotoGroupOption.BY_DATE_CATEGORY,\n            onClick \u003d { onOptionSelected(PhotoGroupOption.BY_DATE_CATEGORY) },\n            text \u003d { Text(\&quot;By Date\&quot;) }\n        )\n        Tab(\n            selected \u003d selectedOption \u003d\u003d PhotoGroupOption.BY_MONTH,\n            onClick \u003d { onOptionSelected(PhotoGroupOption.BY_MONTH) },\n            text \u003d { Text(\&quot;By Month\&quot;) }\n        )\n        Tab(\n            selected \u003d selectedOption \u003d\u003d PhotoGroupOption.ALL,\n            onClick \u003d { onOptionSelected(PhotoGroupOption.ALL) },\n            text \u003d { Text(\&quot;All Photos\&quot;) }\n        )\n    }\n}\n\n@Composable\nfun GroupedPhotosContent(\n    photos: List\u003cPhoto\u003e,\n    onDeletePhoto: (Long) -\u003e Unit\n) {\n    val groupedPhotos \u003d photos.groupByDateCategory()\n\n    LazyColumn(\n        modifier \u003d Modifier.fillMaxSize()\n    ) {\n        groupedPhotos.forEach { (category, photosInCategory) -\u003e\n            item {\n                DateCategoryHeader(category.getDisplayName())\n            }\n\n            item {\n                PhotosGrid(\n                    photos \u003d photosInCategory,\n                    onDeletePhoto \u003d onDeletePhoto\n                )\n            }\n\n            item {\n                Spacer(modifier \u003d Modifier.height(16.dp))\n            }\n        }\n    }\n}\n\n@Composable\nfun MonthlyGroupedPhotosContent(\n    photos: List\u003cPhoto\u003e,\n    onDeletePhoto: (Long) -\u003e Unit\n) {\n    val groupedByMonth \u003d photos.groupBy { photo -\u003e\n        DateUtils.formatDate(photo.createdAt).substringBeforeLast(\&quot;,\&quot;)\n    }.toSortedMap(compareByDescending { it })\n\n    LazyColumn(\n        modifier \u003d Modifier.fillMaxSize()\n    ) {\n        groupedByMonth.forEach { (month, photosInMonth) -\u003e\n            item {\n                DateCategoryHeader(month)\n            }\n\n            item {\n                PhotosGrid(\n                    photos \u003d photosInMonth,\n                    onDeletePhoto \u003d onDeletePhoto\n                )\n            }\n\n            item {\n                Spacer(modifier \u003d Modifier.height(16.dp))\n            }\n        }\n    }\n}\n\n@Composable\nfun AllPhotosContent(\n    photos: List\u003cPhoto\u003e,\n    onDeletePhoto: (Long) -\u003e Unit\n) {\n    Column(modifier \u003d Modifier.fillMaxSize()) {\n        Row(\n            modifier \u003d Modifier\n                .fillMaxWidth()\n                .padding(horizontal \u003d 16.dp, vertical \u003d 8.dp)\n        ) {\n            Text(\n                text \u003d \&quot;All Photos (${photos.size})\&quot;,\n                style \u003d MaterialTheme.typography.titleMedium\n            )\n\n            Spacer(modifier \u003d Modifier.width(8.dp))\n\n            Text(\n                text \u003d if (photos.isNotEmpty()) {\n                    \&quot;Latest: ${DateUtils.formatDate(photos.maxByOrNull { it.createdAt }?.createdAt ?: 0L)}\&quot;\n                } else {\n                    \&quot;\&quot;\n                },\n            