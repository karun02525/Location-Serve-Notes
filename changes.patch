    photoTime.set(Calendar.HOUR_OF_DAY, 0)\n        photoTime.set(Calendar.MINUTE, 0)\n        photoTime.set(Calendar.SECOND, 0)\n        photoTime.set(Calendar.MILLISECOND, 0)\n\n        val diffInMillis \u003d now.timeInMillis - photoTime.timeInMillis\n        val diffInDays \u003d TimeUnit.MILLISECONDS.toDays(diffInMillis)\n\n        return when {\n            diffInDays \u003d\u003d 0L -\u003e \&quot;Today\&quot;\n            diffInDays \u003d\u003d 1L -\u003e \&quot;Yesterday\&quot;\n            diffInDays \u003c 7L -\u003e \&quot;${diffInDays} days ago\&quot;\n            diffInDays \u003c 30L -\u003e \&quot;${diffInDays / 7} week${if (diffInDays / 7 \u003e 1) \&quot;s\&quot; else \&quot;\&quot;} ago\&quot;\n            diffInDays \u003c 365L -\u003e \&quot;${diffInDays / 30} month${if (diffInDays / 30 \u003e 1) \&quot;s\&quot; else \&quot;\&quot;} ago\&quot;\n            else -\u003e formatDate(timestamp)\n        }\n    }\n\n    /**\n     * Formats a timestamp to a standard date string\n     * @param timestamp The timestamp in milliseconds\n     * @return A formatted date string (e.g., \&quot;Jan 1, 2023\&quot;)\n     */\n    fun formatDate(timestamp: Long): String {\n        val date \u003d Date(timestamp)\n        val formatter \u003d SimpleDateFormat(\&quot;MMM d, yyyy\&quot;, Locale.getDefault())\n        return formatter.format(date)\n    }\n\n    /**\n     * Formats a timestamp to a detailed date-time string\n     * @param timestamp The timestamp in milliseconds\n     * @return A formatted date-time string (e.g., \&quot;Jan 1, 2023 3:45 PM\&quot;)\n     */\n    fun formatDateTime(timestamp: Long): String {\n        val date \u003d Date(timestamp)\n        val formatter \u003d SimpleDateFormat(\&quot;MMM d, yyyy h:mm a\&quot;, Locale.getDefault())\n        return formatter.format(date)\n    }\n}\n```&quot;},{&quot;role&quot;:&quot;assistant&quot;,&quot;content&quot;:[{&quot;type&quot;:&quot;text&quot;,&quot;text&quot;:&quot;&quot;}],&quot;tool_calls&quo