+
+// Format seconds to display as HH:MM:SS
+fun formatTime(timeInSeconds: Long): String {
+    val hours = timeInSeconds / 3600
+    val minutes = (timeInSeconds % 3600) / 60
+    val seconds = timeInSeconds % 60
+
+    return String.format("%02d:%02d:%02d", hours, minutes, seconds)
+}
+
+
+fun isPhotoFile(url: String) =
+    url.endsWith(".jpg", ignoreCase = true) || url.endsWith(".mp4", ignoreCase = true)
+
+fun isAudioFile(url: String) =
+    url.endsWith(".mp3", ignoreCase = true)
